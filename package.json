{
  "name": "react-native-north-indian-chart",
  "version": "1.0.0",
  "description": "A fully-typed, dependency-light North Indian (diamond) Vedic astrology / Lagna Kundli chart for React Native, rendered with react-native-svg. Ships the chart, a legend bottom sheet, and a fullscreen modal.",
  "keywords": [
    "react-native",
    "svg",
    "astrology",
    "kundli",
    "lagna",
    "vedic",
    "north-indian-chart",
    "horoscope",
    "panchang",
    "jyotish"
  ],
  "license": "MIT",
  "author": "Nikhil Vashistha <vh9s@ymail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mobile-dev-ci/react-native-north-indian-chart.git"
  },
  "bugs": {
    "url": "https://github.com/mobile-dev-ci/react-native-north-indian-chart/issues"
  },
  "homepage": "https://github.com/mobile-dev-ci/react-native-north-indian-chart#readme",
  "source": "src/index.ts",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "src",
    "dist",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit",
    "screenshots": "node scripts/generate-screenshots.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.68.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "react": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-svg": "^15.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=16"
  }
}
